# Copy to .env (docker compose reads it automatically). Do NOT commit .env.

# Your Gemini API key — enables the in-app chat agent. Without it the rest of
# the app works and the agent shows as disabled.
GEMINI_API_KEY=

# Your Docker Hub username (image namespace).
DOCKERHUB_USER=sidkid1978

# Image tag to build/push/pull.
TAG=latest
